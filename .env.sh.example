# ─────────────────────────────────────────
# 거북이식당 docs — 로컬 환경 변수 템플릿
# 이 파일을 복사해 .env.sh로 저장 후 경로를 설정
#   cp .env.sh.example .env.sh
# ─────────────────────────────────────────

DOCS_DIR="(문서경로)"   # docs 레포 로컬 경로
CODE_DIR="(코드경로)"   # game 레포 로컬 경로
LOCAL_DIR="$HOME"       # ComfyUI 등 홈 디렉토리 기준 경로
